{
  "compilerOptions": {
    "module": "commonjs",
    "target": "ES2020",
    "outDir": "dist",
    "rootDir": ".",
    "lib": ["ES2020"],
    "sourceMap": true,
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "types": ["node"]
  },
  "include": ["src/**/*", "shared/**/*"],
  "exclude": ["node_modules", "dist", "webview-ui", "src/App.tsx", "src/main.tsx", "src/index.html", "src/index.css", "src/components", "src/store", "src/lib", "src/utils", "src/types"]
}
